# Hardhat networks (for npx hardhat run --network <name>)
HARDHAT_SEPOLIA_RPC_URL=
HARDHAT_PRIVATE_KEY=

# Verification (optional; deploy-testnet and deploy-ledger)
ETHERSCAN_API_KEY=
VERIFY_WAIT_BLOCKS=2

# Token
TOKEN_TREASURY=

# Access Pass (ElusivAccessPass)
NFT_MAX_SUPPLY=1000
NFT_MINTING_ENABLED=false
NFT_MINT_PRICE_WEI=100000000000000000
NFT_TREASURY=

# Research Desk
RESEARCH_COST_TOKENS=10
RESEARCH_MAX_QUERY_BYTES=512

# Affiliate / promo (Access Pass). Fee in basis points; token reward in wei.
AFFILIATE_MAX_FEE_BPS=1000
AFFILIATE_DEFAULT_FEE_BPS=1000
AFFILIATE_DEFAULT_TOKEN_REWARD=0
AFFILIATE_ALLOW_SELF_REFERRAL=false
AFFILIATE_REWARDS_ENABLED=true
AFFILIATE_SEED_CODE=
AFFILIATE_SEED_WALLET=
AFFILIATE_SEED_FEE_BPS=1000
AFFILIATE_SEED_TOKEN_REWARD=0

# ContributionDesk: review period (seconds), min/max validator counts
REVIEW_PERIOD=604800
MIN_VALIDATORS=3
MAX_VALIDATORS=5

# deploy-local.js only
SEED_TO=
POOL_FUND_ELUSIV=100000
SKIP_SEED_MINT=

# deploy-simple.js (RPC + private key)
# RPC_URL=https://sepolia.infura.io/v3/<id>
# PRIVATE_KEY=0x...
# MIN_BALANCE_ETH=0.05
# CONFIRMATIONS=2
# ALLOW_MAINNET=0
# DRY_RUN=0

# deploy-ledger.js
# LEDGER_DERIVATION_PATH=44'/60'/0'/0/0
# CONFIRMATIONS=2
# DRY_RUN=0
